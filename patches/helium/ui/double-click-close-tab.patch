--- a/chrome/browser/ui/views/tabs/tab.cc
+++ b/chrome/browser/ui/views/tabs/tab.cc
@@ -852,6 +852,14 @@ bool Tab::OnMousePressed(const ui::Mouse
   // This and the release handler are interested in order to discumbate between
   // activation clicks and drag initiation.
   if (event.is_left_click()) {
+    // Double-click to close tab.
+    const base::TimeTicks now = base::TimeTicks::Now();
+    constexpr base::TimeDelta kDoubleClickInterval =
+        base::Milliseconds(500);
+    if (now - last_left_click_time_ <= kDoubleClickInterval) {
+      last_left_click_time_ = base::TimeTicks();
+      controller_->CloseTab(this, CloseTabSource::kFromMouse);
+    }
+    last_left_click_time_ = now;
     shift_pressed_on_mouse_down_ = event.shift_down();
   }
   return true;
